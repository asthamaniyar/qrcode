{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/r/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "5003",
    "DOMAIN": "http://qrer.errorinfotech.in",
    "FRONTEND_URL": "http://qrer.errorinfotech.in"
  },
  "cors": {
    "origin": ["http://localhost:5173", "http://localhost:5174", "http://qrer.errorinfotech.in"],
    "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "headers": ["Content-Type", "Authorization"]
  }
}
